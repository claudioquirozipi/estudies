---
import Layout from './Layout.astro';

interface Props {
  title: string;
  description: string;
  color: string;
  topic: string;
  topicHref: string;
  category: string;
}

const { title, description, color, topic, topicHref, category } = Astro.props;
---

<Layout title={`${title} — Mi Cuaderno`} description={description}>
  <div class="page-wrapper">
    <header class="concept-header">
      <nav class="breadcrumb">
        <a href="/">Inicio</a>
        <span class="sep">/</span>
        <a href={topicHref}>{topic}</a>
        <span class="sep">/</span>
        <span>{category}</span>
        <span class="sep">/</span>
        <span class="current">{title}</span>
      </nav>
      <div class="topic-meta">
        <span
          class="topic-label"
          style={`background: ${color}18; color: ${color}; border-color: ${color}35`}
        >
          {topic}
        </span>
        <span class="category-label">{category}</span>
      </div>
      <h1 class="concept-title">{title}</h1>
      <p class="concept-description">{description}</p>
      <div
        class="concept-rule"
        style={`background: linear-gradient(90deg, ${color} 0%, transparent 100%)`}
      >
      </div>
    </header>

    <main class="concept-content">
      <slot />
    </main>

    <footer class="concept-footer">
      <a href={topicHref} class="back-link">← Volver al roadmap de {topic}</a>
    </footer>
  </div>
</Layout>

<style>
  .page-wrapper {
    max-width: 860px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .concept-header {
    padding: 3rem 0 2.5rem;
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.4rem;
    font-size: 0.85rem;
    color: var(--text-dim);
    margin-bottom: 1.25rem;
  }

  .breadcrumb a {
    color: var(--text-muted);
    transition: color 0.15s;
  }

  .breadcrumb a:hover {
    color: var(--text);
  }

  .breadcrumb .current {
    color: var(--text-muted);
  }

  .sep {
    color: var(--text-dim);
  }

  .topic-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }

  .topic-label {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
    border: 1px solid;
  }

  .category-label {
    font-size: 0.78rem;
    color: var(--text-dim);
  }

  .concept-title {
    font-size: 2.25rem;
    font-weight: 700;
    color: var(--color-title);
    margin-bottom: 0.75rem;
  }

  .concept-description {
    color: var(--text-muted);
    font-size: 1.05rem;
    max-width: 58ch;
    line-height: 1.7;
  }

  .concept-rule {
    height: 2px;
    width: 80px;
    border-radius: 2px;
    margin-top: 2rem;
  }

  .concept-content {
    display: flex;
    flex-direction: column;
    gap: 3rem;
    padding-bottom: 5rem;
  }

  .concept-footer {
    padding: 2rem 0;
    border-top: 1px solid var(--border);
  }

  .back-link {
    color: var(--text-muted);
    font-size: 0.875rem;
    transition: color 0.15s;
  }

  .back-link:hover {
    color: var(--text);
  }

  @media (max-width: 640px) {
    .concept-title {
      font-size: 1.75rem;
    }
  }
</style>
