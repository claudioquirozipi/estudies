---
interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'Mi Cuaderno de Estudio',
  description = 'Guia de estudio personal de desarrollo web y backend',
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Fira+Code:wght@300;400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  :root {
    --bg: linear-gradient(180deg, #76C8E0 0%, #AED8E6 50%, #2A8CCB 100%);
    /* --bg-card: linear-gradient(135deg, #58A4DE 0%,#8B9DB2 70%, #183F4E 100%); */
    --bg-card: linear-gradient(135deg, #D7DFE1 0%,#D7DFE1 50%, #BAE0E9 100%);
    --bg-card-hover: linear-gradient(135deg, #D7DFE1 0%,#D7DFE1 75%, #BAE0E9 100%);
    --text: #0E2B43;
    --text-muted: rgba(14, 43, 67, 0.65);
    --text-dim: rgba(14, 43, 67, 0.4);
    --border: #181410;
    --border-light: #201c16;
    /* --color-title: #77B207; */
    /* --color-title: #78AA0B; */
    --color-title: #244E00;
    --font-sans: 'Space Grotesk', system-ui, sans-serif;
    --font-mono: 'Fira Code', 'Cascadia Code', monospace;
  }

  html {
    background: var(--bg);
    color: var(--text);
    font-family: var(--font-sans);
    font-size: 16px;
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  body {
    min-height: 100vh;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  code:not(pre > code) {
    font-family: var(--font-mono);
    font-size: 0.875em;
    background: #130f0a;
    border: 1px solid var(--border-light);
    border-radius: 4px;
    padding: 0.1em 0.4em;
    color: #8a7055;
  }

  pre {
    border-radius: 10px;
    overflow-x: auto;
    line-height: 1.7;
    font-family: var(--font-mono);
    border: 1px solid var(--border);
  }

  h1,
  h2,
  h3,
  h4,
  h5,
  h6 {
    line-height: 1.3;
    font-weight: 600;
    color: var(--color-title);
  }

  p {
    line-height: 1.75;
    color: var(--text);
  }

  .section {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .section-title {
    font-size: 1.3rem;
    font-weight: 600;
    padding-bottom: 0.6rem;
    border-bottom: 1px solid var(--border);
  }

  .section-desc {
    color: var(--text-muted);
    font-size: 0.95rem;
    line-height: 1.75;
  }

  .note {
    background: #0e0b08;
    border-left: 3px solid #6b5030;
    border-radius: 0 6px 6px 0;
    padding: 0.75rem 1rem;
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.65;
  }

  .note strong {
    color: #8a6840;
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .tag {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    padding: 0.2rem 0.55rem;
    background: #0e0b08;
    border: 1px solid var(--border-light);
    border-radius: 4px;
    color: var(--text-muted);
  }

  .placeholder-content {
    text-align: center;
    padding: 5rem 2rem;
    color: var(--text-dim);
  }

  .placeholder-content .ph-icon {
    font-size: 2.5rem;
    margin-bottom: 1.25rem;
  }

  .placeholder-content h3 {
    color: var(--text-muted);
    font-size: 1.15rem;
    margin-bottom: 0.4rem;
  }

  .placeholder-content p {
    color: var(--text-dim);
    font-size: 0.875rem;
  }
</style>
