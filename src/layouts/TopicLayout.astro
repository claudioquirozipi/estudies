---
import Layout from './Layout.astro';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  title: string;
  description: string;
  color: string;
  topic: string;
  slug: string;
  logo?: ImageMetadata;
}

const { title, description, color, topic, slug, logo } = Astro.props;
---

<Layout title={`${title} — Mi Cuaderno`} description={description}>
  <div class="page-wrapper">
    <header class="topic-header">
      <nav class="breadcrumb">
        <a href="/">← Inicio</a>
        <span class="sep">/</span>
        <span>{title}</span>
      </nav>
      <div class="topic-meta">
        {logo && (
          <div class="topic-logo" style={`background: ${color}18; border-color: ${color}35`}>
            <Image src={logo} alt={`Logo de ${title}`} width={48} height={48} transition:name={`logo-${slug}`} />
          </div>
        )}
        <span
          class="topic-label"
          style={`background: ${color}18; color: ${color}; border-color: ${color}35`}
        >
          {topic}
        </span>
      </div>
      <h1 class="topic-title" transition:name={`title-${slug}`}>{title}</h1>
      <p class="topic-description">{description}</p>
      <div
        class="topic-rule"
        style={`background: linear-gradient(90deg, ${color} 0%, transparent 100%)`}
      >
      </div>
    </header>

    <main class="topic-content">
      <slot />
    </main>

    <footer class="topic-footer">
      <a href="/" class="back-link">← Volver al inicio</a>
    </footer>
  </div>
</Layout>

<style>
  .page-wrapper {
    max-width: 860px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .topic-header {
    padding: 3rem 0 2.5rem;
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.85rem;
    color: var(--text-dim);
    margin-bottom: 1.25rem;
  }

  .breadcrumb a {
    color: var(--text-muted);
    transition: color 0.15s;
  }

  .breadcrumb a:hover {
    color: var(--text);
  }

  .sep {
    color: var(--text-dim);
  }

  .topic-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }

  .topic-logo {
    width: 3rem;
    height: 3rem;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.5rem;
    border-radius: 8px;
    border: 1px solid;
  }

  .topic-logo img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .topic-label {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
    border: 1px solid;
  }

  .topic-title {
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--color-title);
    margin-bottom: 0.75rem;
  }

  .topic-description {
    color: var(--text-muted);
    font-size: 1.05rem;
    max-width: 58ch;
    line-height: 1.7;
  }

  .topic-rule {
    height: 2px;
    width: 80px;
    border-radius: 2px;
    margin-top: 2rem;
  }

  .topic-content {
    display: flex;
    flex-direction: column;
    gap: 3rem;
    padding-bottom: 5rem;
  }

  .topic-footer {
    padding: 2rem 0;
    border-top: 1px solid var(--border);
  }

  .back-link {
    color: var(--text-muted);
    font-size: 0.875rem;
    transition: color 0.15s;
  }

  .back-link:hover {
    color: var(--text);
  }

  @media (max-width: 640px) {
    .topic-title {
      font-size: 1.85rem;
    }
  }
</style>
