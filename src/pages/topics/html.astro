---
import TopicLayout from '../../layouts/TopicLayout.astro';
import { Code } from 'astro:components';
---

<TopicLayout
  title="HTML"
  description="La estructura base de la web. Semantica, accesibilidad, formularios y optimizacion de rendimiento."
  color="#e34c26"
  topic="HTML"
>
  <!-- 1. Estructura del documento -->
  <div class="section">
    <h2 class="section-title">Estructura del Documento</h2>
    <p class="section-desc">
      El <code>lang</code> en <code>&lt;html&gt;</code> es critico para lectores de pantalla y SEO.
      <code>charset</code> siempre UTF-8. El <code>viewport</code> es obligatorio para sitios responsive.
    </p>
    <Code
      code={`<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Descripcion de 150-160 caracteres." />
    <title>Titulo de la pagina | Sitio</title>
    <link rel="canonical" href="https://ejemplo.com/pagina" />
  </head>
  <body>
    <!-- contenido -->
  </body>
</html>`}
      lang="html"
      theme="rose-pine"
    />
  </div>

  <!-- 2. Elementos semanticos -->
  <div class="section">
    <h2 class="section-title">Elementos Semanticos</h2>
    <p class="section-desc">
      HTML5 introduce elementos con significado inherente. Usarlos correctamente mejora accesibilidad,
      SEO y mantenibilidad. Nunca uses <code>&lt;div&gt;</code> donde existe un elemento semantico apropiado.
    </p>
    <Code
      code={`<body>
  <header>          <!-- cabecera del sitio o de una seccion -->
    <nav>           <!-- navegacion principal -->
      <ul>
        <li><a href="/">Inicio</a></li>
        <li><a href="/blog" aria-current="page">Blog</a></li>
      </ul>
    </nav>
  </header>

  <main>            <!-- contenido principal — solo uno por pagina -->
    <article>       <!-- contenido independiente y autocontenido -->
      <header>
        <h1>Titulo del articulo</h1>
        <time datetime="2024-06-15">15 de junio, 2024</time>
      </header>

      <section>     <!-- agrupacion tematica dentro del articulo -->
        <h2>Subtitulo</h2>
        <p>Contenido...</p>
      </section>

      <figure>      <!-- contenido ilustrativo (imagen, video, codigo) -->
        <img src="grafico.png" alt="Descripcion del grafico" />
        <figcaption>Figura 1: descripcion</figcaption>
      </figure>
    </article>

    <aside>         <!-- contenido relacionado pero secundario -->
      <h3>Articulos relacionados</h3>
    </aside>
  </main>

  <footer>          <!-- pie del sitio o de una seccion -->
    <address>       <!-- informacion de contacto del autor -->
      <a href="mailto:hola@ejemplo.com">hola@ejemplo.com</a>
    </address>
  </footer>
</body>`}
      lang="html"
      theme="rose-pine"
    />
    <div class="tag-list">
      <span class="tag">&lt;main&gt;</span>
      <span class="tag">&lt;article&gt;</span>
      <span class="tag">&lt;section&gt;</span>
      <span class="tag">&lt;nav&gt;</span>
      <span class="tag">&lt;aside&gt;</span>
      <span class="tag">&lt;header&gt;</span>
      <span class="tag">&lt;footer&gt;</span>
      <span class="tag">&lt;time&gt;</span>
      <span class="tag">&lt;address&gt;</span>
      <span class="tag">&lt;figure&gt;</span>
      <span class="tag">&lt;figcaption&gt;</span>
      <span class="tag">&lt;mark&gt;</span>
      <span class="tag">&lt;details&gt;</span>
      <span class="tag">&lt;summary&gt;</span>
      <span class="tag">&lt;dialog&gt;</span>
    </div>
  </div>

  <!-- 3. Formularios -->
  <div class="section">
    <h2 class="section-title">Formularios Modernos</h2>
    <p class="section-desc">
      HTML5 expande los tipos de input y agrega validacion nativa. Siempre asocia
      <code>&lt;label&gt;</code> con su input via <code>for</code>/<code>id</code>.
      <code>autocomplete</code> mejora UX y es requerido en muchos formularios de pago (PCI).
    </p>
    <Code
      code={`<form method="POST" action="/api/contact" novalidate>
  <fieldset>
    <legend>Informacion de contacto</legend>

    <label for="nombre">Nombre <span aria-hidden="true">*</span></label>
    <input
      type="text"
      id="nombre"
      name="nombre"
      required
      autocomplete="given-name"
      minlength="2"
      maxlength="100"
    />

    <label for="email">Correo electronico</label>
    <input type="email" id="email" name="email" required autocomplete="email" />

    <!-- Tipos modernos con validacion nativa -->
    <input type="date" />
    <input type="number" min="0" max="100" step="5" />
    <input type="tel"  autocomplete="tel" />
    <input type="url" />
    <input type="color" />
    <input type="range" min="0" max="10" />
    <input type="search" role="searchbox" />

    <!-- datalist: autocomplete con opciones predefinidas -->
    <input list="paises-list" name="pais" placeholder="Pais" />
    <datalist id="paises-list">
      <option value="Mexico" />
      <option value="Colombia" />
      <option value="Argentina" />
    </datalist>

    <!-- Atributos de validacion -->
    <input type="text" pattern="[A-Za-z]{3}" title="Tres letras" />
    <textarea name="mensaje" rows="4" maxlength="500"></textarea>

    <!-- Select con optgroup -->
    <select name="categoria">
      <optgroup label="Frontend">
        <option value="react">React</option>
        <option value="angular">Angular</option>
      </optgroup>
      <optgroup label="Backend">
        <option value="node">Node.js</option>
      </optgroup>
    </select>
  </fieldset>

  <button type="submit">Enviar</button>
  <button type="reset">Limpiar</button>
</form>`}
      lang="html"
      theme="rose-pine"
    />
  </div>

  <!-- 4. Accesibilidad -->
  <div class="section">
    <h2 class="section-title">Accesibilidad (ARIA)</h2>
    <p class="section-desc">
      ARIA complementa HTML cuando los elementos nativos no son suficientes.
      Primera regla de ARIA: usa el elemento HTML nativo correcto antes de agregar roles o atributos ARIA.
    </p>
    <Code
      code={`<!-- Roles -->
<div role="alert">Error: campo requerido</div>         <!-- anuncio urgente -->
<div role="status">Guardado correctamente</div>        <!-- anuncio no urgente -->
<div role="dialog" aria-labelledby="modal-title" aria-modal="true">

<!-- Estados y propiedades -->
<button aria-expanded="false" aria-controls="menu-id">Menu</button>
<ul id="menu-id" aria-hidden="true">...</ul>

<input
  aria-required="true"
  aria-invalid="true"
  aria-describedby="campo-error"
/>
<span id="campo-error" role="alert">Este campo es requerido</span>

<!-- Labels cuando no hay texto visible -->
<button aria-label="Cerrar modal">✕</button>
<nav aria-label="Navegacion principal">...</nav>
<nav aria-label="Breadcrumb" aria-current="page">...</nav>

<!-- Imagenes -->
<img src="foto.jpg" alt="Descripcion significativa de la imagen" />
<img src="decorativo.svg" alt="" role="presentation" />  <!-- ignorada por screen readers -->

<!-- Skip link (accesibilidad para teclado) -->
<a href="#main-content" class="skip-link">Saltar al contenido</a>
<main id="main-content">...</main>

<!-- Live regions: anuncian cambios dinamicos -->
<div aria-live="polite" aria-atomic="true" aria-relevant="text">
  <!-- Cambios en este elemento son anunciados automaticamente -->
</div>

<!-- tabindex -->
<div tabindex="0">Focusable con Tab</div>              <!-- en tab order -->
<div tabindex="-1" id="modal">Focusable solo via JS</div>  <!-- no en tab order -->`}
      lang="html"
      theme="rose-pine"
    />
    <div class="note">
      <strong>Regla principal:</strong> si existe un elemento HTML nativo que hace lo que necesitas
      (<code>button</code>, <code>a</code>, <code>input</code>, <code>select</code>...), usalo.
      ARIA no reemplaza la semantica nativa, la complementa cuando es insuficiente.
    </div>
  </div>

  <!-- 5. Meta tags y SEO -->
  <div class="section">
    <h2 class="section-title">Meta Tags, SEO y Open Graph</h2>
    <p class="section-desc">
      Las meta tags controlan como buscadores y redes sociales presentan tu pagina.
      Open Graph es el estandar para previsualizaciones en redes sociales.
      Twitter Cards son especificas de X (Twitter).
    </p>
    <Code
      code={`<head>
  <!-- SEO basico -->
  <meta name="description" content="Descripcion de 150-160 caracteres." />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href="https://ejemplo.com/pagina" />

  <!-- Open Graph (Facebook, LinkedIn, WhatsApp, Slack...) -->
  <meta property="og:type" content="website" />        <!-- website | article | product -->
  <meta property="og:title" content="Titulo de la pagina" />
  <meta property="og:description" content="Descripcion para redes sociales." />
  <meta property="og:image" content="https://ejemplo.com/og-image.jpg" />  <!-- 1200x630 px -->
  <meta property="og:url" content="https://ejemplo.com/pagina" />
  <meta property="og:site_name" content="Nombre del sitio" />
  <meta property="og:locale" content="es_MX" />

  <!-- Twitter / X Cards -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="Titulo de la pagina" />
  <meta name="twitter:description" content="Descripcion." />
  <meta name="twitter:image" content="https://ejemplo.com/og-image.jpg" />
  <meta name="twitter:creator" content="@tuusuario" />

  <!-- Favicons (estrategia moderna) -->
  <link rel="icon" href="/favicon.ico" sizes="any" />        <!-- legacy -->
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" /> <!-- moderno, soporta dark mode -->
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/site.webmanifest" />
  <meta name="theme-color" content="#141210" />

  <!-- Rendimiento: preconectar a dominios externos -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="dns-prefetch" href="https://analytics.example.com" />
</head>`}
      lang="html"
      theme="rose-pine"
    />
  </div>

  <!-- 6. Rendimiento -->
  <div class="section">
    <h2 class="section-title">Rendimiento y Carga de Recursos</h2>
    <p class="section-desc">
      HTML ofrece atributos nativos para controlar cuando y como se cargan los recursos.
      Impactan directamente en Core Web Vitals (LCP, CLS, INP).
    </p>
    <Code
      code={`<!-- IMAGENES -->

<!-- lazy: no carga hasta que el usuario se acerca — no usar en above-the-fold -->
<img src="foto.jpg" alt="..." loading="lazy" decoding="async" />

<!-- eager + fetchpriority: para la imagen principal (LCP) -->
<img src="hero.jpg" alt="..." loading="eager" fetchpriority="high"
     width="1200" height="600" />

<!-- Siempre especifica width/height para evitar layout shift (CLS) -->
<img src="avatar.jpg" alt="..." width="80" height="80" />

<!-- Picture: formatos modernos con fallback -->
<picture>
  <source type="image/avif" srcset="imagen.avif" />
  <source type="image/webp" srcset="imagen.webp" />
  <img src="imagen.jpg" alt="Descripcion" width="800" height="450" />
</picture>

<!-- srcset + sizes: imagenes responsivas -->
<img
  src="imagen-400.jpg"
  srcset="imagen-400.jpg 400w, imagen-800.jpg 800w, imagen-1600.jpg 1600w"
  sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 800px"
  alt="Descripcion"
  loading="lazy"
  decoding="async"
/>


<!-- SCRIPTS -->

<!-- defer: ejecuta en orden, despues de parsear HTML — lo mas comun -->
<script src="app.js" defer></script>

<!-- async: ejecuta tan pronto como carga, sin orden garantizado — para scripts independientes -->
<script src="analytics.js" async></script>

<!-- type="module": defer por default, scope propio, strict mode -->
<script type="module" src="main.js"></script>


<!-- PRELOAD / PREFETCH / PRECONNECT -->

<!-- preload: recurso critico en la pagina actual (fuentes, imagen LCP, CSS critico) -->
<link rel="preload" href="fuente.woff2" as="font" type="font/woff2" crossorigin />
<link rel="preload" href="hero.jpg" as="image" />

<!-- prefetch: recurso que probablemente se necesitara en la siguiente navegacion -->
<link rel="prefetch" href="/dashboard" />

<!-- preconnect: establece conexion TCP+TLS con dominio externo por adelantado -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />`}
      lang="html"
      theme="rose-pine"
    />
    <div class="note">
      <strong>Tip LCP:</strong> la imagen above-the-fold mas grande (Largest Contentful Paint) debe
      tener <code>loading="eager"</code>, <code>fetchpriority="high"</code> y un
      <code>&lt;link rel="preload"&gt;</code> en el <code>&lt;head&gt;</code>.
      Las demas imagenes: <code>loading="lazy"</code> y <code>decoding="async"</code>.
    </div>
  </div>

  <!-- 7. Elementos interactivos modernos -->
  <div class="section">
    <h2 class="section-title">Elementos Interactivos Nativos</h2>
    <p class="section-desc">
      HTML tiene elementos interactivos que antes requerían JavaScript. Conocerlos evita
      reinventar la rueda y garantiza accesibilidad desde el inicio.
    </p>
    <Code
      code={`<!-- dialog: modal nativo con accesibilidad incluida -->
<dialog id="mi-modal">
  <h2>Titulo del modal</h2>
  <p>Contenido del modal</p>
  <button onclick="this.closest('dialog').close()">Cerrar</button>
</dialog>
<button onclick="document.getElementById('mi-modal').showModal()">
  Abrir modal
</button>

<!-- details + summary: accordion nativo -->
<details>
  <summary>Pregunta frecuente</summary>
  <p>Respuesta detallada aqui. Se muestra al hacer click en summary.</p>
</details>

<!-- popover API (nuevo en 2024) -->
<button popovertarget="mi-popover">Abrir popover</button>
<div id="mi-popover" popover>
  Contenido del popover. Se cierra con Escape o click fuera.
</div>

<!-- meter: valor en un rango conocido -->
<meter value="0.7" min="0" max="1" low="0.3" high="0.8" optimum="1">70%</meter>

<!-- progress: progreso de una tarea -->
<progress value="45" max="100">45%</progress>

<!-- output: resultado de un calculo -->
<form oninput="resultado.value = parseInt(a.value) + parseInt(b.value)">
  <input type="number" name="a" value="0" /> +
  <input type="number" name="b" value="0" /> =
  <output name="resultado">0</output>
</form>

<!-- contenteditable: hacer cualquier elemento editable -->
<div contenteditable="true" role="textbox" aria-multiline="true">
  Texto editable por el usuario
</div>`}
      lang="html"
      theme="rose-pine"
    />
  </div>

  <!-- 8. Data attributes -->
  <div class="section">
    <h2 class="section-title">Data Attributes</h2>
    <p class="section-desc">
      Los atributos <code>data-*</code> permiten almacenar datos personalizados directamente en
      el HTML, accesibles desde JavaScript via <code>dataset</code>. Utiles para conectar
      HTML con comportamiento JS sin clases o IDs artificiales.
    </p>
    <Code
      code={`<!-- HTML -->
<button
  data-action="toggle"
  data-target="sidebar"
  data-animate="true"
  data-delay="300"
>
  Toggle sidebar
</button>

<div
  data-component="carousel"
  data-autoplay="true"
  data-interval="5000"
  data-slides="3"
>
  ...
</div>

<!-- JavaScript -->
const btn = document.querySelector('[data-action="toggle"]');

// Leer
const target = btn.dataset.target;   // "sidebar"
const delay = btn.dataset.delay;     // "300" (siempre string)

// Escribir
btn.dataset.active = "true";         // agrega data-active="true"

// Eliminar
delete btn.dataset.active;

// CSS puede leer data attributes
// [data-active="true"] { background: green; }

// querySelector con data attributes
const carousels = document.querySelectorAll('[data-component="carousel"]');`}
      lang="javascript"
      theme="rose-pine"
    />
    <div class="note">
      <strong>Nota:</strong> los data attributes son para datos de UI/comportamiento, no para datos
      de negocio criticos. Para leer/escribir frecuentemente desde JS, considera usar state en lugar
      de data attributes como fuente de verdad.
    </div>
  </div>
</TopicLayout>
