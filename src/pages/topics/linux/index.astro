---
import TopicLayout from '../../../layouts/TopicLayout.astro';
import RoadmapNode from '../../../components/RoadmapNode.astro';
import linuxLogo from '../../../assets/logos/linux.png';

const color = '#dd8500';

const roadmap = [
  {
    title: 'Fundamentos',
    children: [
      { title: 'Estructura de carpetas', href: '/topics/linux/fundamentos/estructura-carpetas' },
      { title: 'Comandos básicos de Bash', href: '/topics/linux/fundamentos/comandos-basicos' },
    ],
  },
];
---

<TopicLayout
  title="Linux"
  description="La jerarquía de directorios del sistema y los comandos de Bash más usados en el día a día."
  color={color}
  topic="Linux"
  slug="linux"
  logo={linuxLogo}
>
  <div class="roadmap">
    {
      roadmap.map((category) => (
        <div class="roadmap-card" style={`--color: ${color}`}>
          <div class="roadmap-card-accent" />
          <h3 class="roadmap-card-title">{category.title}</h3>
          <div class="roadmap-card-body">
            {category.children?.map((child) => <RoadmapNode node={child} />)}
          </div>
        </div>
      ))
    }
  </div>
</TopicLayout>

<style>
  .roadmap {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .roadmap-card {
    position: relative;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.25rem 1.4rem 1.4rem;
    overflow: hidden;
  }

  .roadmap-card-accent {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--color);
    opacity: 0.75;
  }

  .roadmap-card-title {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 0.75rem;
  }

  .roadmap-card-body {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }
</style>
